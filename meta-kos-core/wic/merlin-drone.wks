# short-description: Create MerlinOS SD card image for Drone
# long-description: Creates a partitioned SD card image with a read-only rootfs and writable data partition.

part /boot --source bootimg-partition --ondisk mmcblk0 --fstype=vfat --label boot --active --align 4096 --size 100
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label root --align 4096
part /data --ondisk mmcblk0 --fstype=ext4 --label data --align 4096 --size 1024
